<launch>
  <arg name="robot_name" default="leatherback" description="TurtleBot name — used to look up domain/discovery via robot-setup.sh"/>

  <executable
    cmd='bash -lc "$HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/src/topological_nav/scripts/ros_launch_node.sh $(var robot_name) $HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/venv/bin/python -m topological_nav.person_follow_node"'
    output="screen"/>

  <executable
    cmd='bash -lc "$HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/src/topological_nav/scripts/ros_launch_node.sh $(var robot_name) $HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/venv/bin/python -m topological_nav.gesture_node"'
    output="screen"/>

  <executable
    cmd='bash -lc "$HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/src/topological_nav/scripts/ros_launch_node.sh $(var robot_name) $HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/venv/bin/python -m topological_nav.qr_node"'
    output="screen"/>

  <executable
    cmd='bash -lc "$HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/src/topological_nav/scripts/ros_launch_node.sh $(var robot_name) $HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/venv/bin/python -m topological_nav.follow_manager"'
    output="screen"/>

  <executable
    cmd='bash -lc "$HOME/robotics/ros2-topological-mapping-navigation/ros2_ws/src/topological_nav/scripts/ros_launch_node.sh $(var robot_name) ros2 run topological_nav tts_node"'
    output="screen"/>
</launch>
