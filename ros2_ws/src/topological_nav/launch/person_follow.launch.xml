<launch>
  <arg name="robot_name" default="" description="TurtleBot name printed on the robot"/>

  <!-- bash -lc loads .bashrc which has the lab ROS_DOMAIN_ID + ROS_DISCOVERY_SERVER.
       We then unset ROS_LOCALHOST_ONLY (set by setup.bash) so nodes can reach the robot,
       and source the workspace overlay so topological_nav is importable. -->

  <!-- Person follow — YOLOv8n detects people, robot drives toward them -->
  <executable
    cmd='bash -lc "unset ROS_LOCALHOST_ONLY &amp;&amp; source ~/robotics/ros2-topological-mapping-navigation/ros2_ws/install/setup.bash &amp;&amp; ~/robotics/ros2-topological-mapping-navigation/ros2_ws/venv/bin/python -m topological_nav.person_follow_node"'
    output="screen"/>

  <!-- Gesture node — MediaPipe hand detection, throttled to 5fps -->
  <executable
    cmd='bash -lc "unset ROS_LOCALHOST_ONLY &amp;&amp; source ~/robotics/ros2-topological-mapping-navigation/ros2_ws/install/setup.bash &amp;&amp; ~/robotics/ros2-topological-mapping-navigation/ros2_ws/venv/bin/python -m topological_nav.gesture_node"'
    output="screen"/>

  <!-- QR node — scans QR codes when /person_follow_active is True -->
  <executable
    cmd='bash -lc "unset ROS_LOCALHOST_ONLY &amp;&amp; source ~/robotics/ros2-topological-mapping-navigation/ros2_ws/install/setup.bash &amp;&amp; ~/robotics/ros2-topological-mapping-navigation/ros2_ws/venv/bin/python -m topological_nav.qr_node"'
    output="screen"/>

  <!-- Follow manager — gesture 5 toggles following on/off -->
  <executable
    cmd='bash -lc "unset ROS_LOCALHOST_ONLY &amp;&amp; source ~/robotics/ros2-topological-mapping-navigation/ros2_ws/install/setup.bash &amp;&amp; ~/robotics/ros2-topological-mapping-navigation/ros2_ws/venv/bin/python -m topological_nav.follow_manager"'
    output="screen"/>

  <!-- Text-to-speech (robot side) -->
  <executable
    cmd='bash -lc "unset ROS_LOCALHOST_ONLY &amp;&amp; source ~/robotics/ros2-topological-mapping-navigation/ros2_ws/install/setup.bash &amp;&amp; ros2 run topological_nav tts_node"'
    output="screen"/>
</launch>
