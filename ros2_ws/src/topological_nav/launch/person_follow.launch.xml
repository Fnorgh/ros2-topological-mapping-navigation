<launch>
  <arg name="robot_name" default="" description="TurtleBot name printed on the robot"/>
  <arg name="venv_python" default="python3" description="Path to venv python (e.g. /home/user/ros2_ws/venv/bin/python)"/>

  <!-- Person follow — YOLOv8n detects people, robot drives toward them -->
  <!-- Enable/disable: ros2 topic pub /person_follow_active std_msgs/Bool "data: true" -->
  <executable
    cmd='bash -c "unset ROS_LOCALHOST_ONLY &amp;&amp; $(var venv_python) -m topological_nav.person_follow_node"'
    output="screen"/>

  <!-- Gesture node — optional, for triggering other behaviours -->
  <executable
    cmd='bash -c "unset ROS_LOCALHOST_ONLY &amp;&amp; $(var venv_python) -m topological_nav.gesture_node"'
    output="screen"/>

  <!-- Text-to-speech (robot side — no audio hardware, use speak_listener on your computer instead) -->
  <executable
    cmd='bash -c "unset ROS_LOCALHOST_ONLY &amp;&amp; ros2 run topological_nav tts_node"'
    output="screen"/>
</launch>
